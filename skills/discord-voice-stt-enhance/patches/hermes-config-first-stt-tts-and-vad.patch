+    @classmethod
+    def _pcm_looks_speech_like(cls, pcm_data: bytes) -> bool:
+        """Return True when a completed PCM buffer has speech-like energy.
+
+        This is an admission gate before STT. Discord voice buffers can contain
+        near-silence, hum, or decode residue that Whisper-like models turn into
+        plausible hallucinations. Keep the heuristic conservative: accept any
+        buffer with enough whole-buffer RMS, otherwise require enough voiced
+        20ms frames.
+        """
+        if len(pcm_data) < 2:
+            return False
+        sample_bytes = len(pcm_data) - (len(pcm_data) % 2)
+        if sample_bytes <= 0:
+            return False
+        samples = array('h')
+        samples.frombytes(pcm_data[:sample_bytes])
+        if not samples:
+            return False
+
+        peak = max(abs(sample) for sample in samples)
+        if peak < cls.MIN_BUFFER_PEAK:
+            return False
+
+        rms = (sum(sample * sample for sample in samples) / len(samples)) ** 0.5
+        if rms >= cls.MIN_BUFFER_RMS:
+            return True
+
+        frame_samples = max(1, int(cls.SAMPLE_RATE * 0.02) * cls.CHANNELS)
+        total_frames = 0
+        voiced_frames = 0
+        for idx in range(0, len(samples), frame_samples):
+            frame = samples[idx:idx + frame_samples]
+            if not frame:
+                continue
+            total_frames += 1
+            frame_rms = (sum(sample * sample for sample in frame) / len(frame)) ** 0.5
+            if frame_rms >= cls.VOICED_FRAME_RMS:
+                voiced_frames += 1
+
+        return bool(total_frames and (voiced_frames / total_frames) >= cls.MIN_VOICED_FRAME_RATIO)
+
