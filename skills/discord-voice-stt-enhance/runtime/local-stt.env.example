# Copy values you want into your shell, ~/.profile, a Windows environment block, or a systemd EnvironmentFile.
HERMES_LOCAL_STT_HOST=127.0.0.1
HERMES_LOCAL_STT_PORT=8177
HERMES_LOCAL_STT_MODEL=large-v3-turbo
HERMES_LOCAL_STT_DEVICE=cuda
HERMES_LOCAL_STT_COMPUTE_TYPE=int8_float16
HERMES_LOCAL_STT_CPU_COMPUTE_TYPE=int8
HERMES_LOCAL_STT_CACHE_DIR=/home/jinwang/workspace/discord-voice-stt-enhance/runtime/.cache/models
HERMES_LOCAL_STT_TIMEOUT=60
HERMES_LOCAL_STT_SERVER_URL=http://127.0.0.1:8177
# For a Windows GPU host serving a Linux VM, bind the runtime with HERMES_LOCAL_STT_HOST=0.0.0.0
# and point Hermes in the VM at HERMES_LOCAL_STT_SERVER_URL=http://WINDOWS_HOST_IP:8177
