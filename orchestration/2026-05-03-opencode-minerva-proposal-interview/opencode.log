  checkpoints: state/checkpoints.json
hermes:
  integration_mode: boundary-cli
  deliver_channel: discord-origin
reproducibility:
  packaging: pyproject
  config_format: yaml
  project_name: jinwang-jarvis
''', encoding='utf-8')

def run(args):
    completed = subprocess.run([sys.executable, '-m', 'jinwang_jarvis.cli', *args], cwd='/home/jinwang/workspace/jinwang-jarvis', env={**dict(PYTHONPATH='src'), **{}}, text=True, capture_output=True, check=True)
    return json.loads(completed.stdout)

started = run(['minerva', 'start', '--config', str(config), '--goal', 'Manual QA proposal interview', '--origin-platform', 'discord', '--origin-channel-id', 'parent'])
run_id = started['run_id']
cards_path = root / 'data' / 'minerva' / run_id / 'discord_cards.jsonl'
first_card = json.loads(cards_path.read_text(encoding='utf-8').splitlines()[-1])
first_actions = [component['action'] for component in first_card['card']['components']]
first_dimension = first_card['card']['proposal_card']['dimension']
first_custom_id = first_card['card']['components'][0]['custom_id']
selected = run(['minerva', 'interact', '--config', str(config), '--run-id', run_id, '--custom-id', first_custom_id, '--origin-channel-id', 'parent'])
next_card = json.loads(cards_path.read_text(encoding='utf-8').splitlines()[-1])
print(json.dumps({
    'workspace': str(root),
    'run_id': run_id,
    'first_dimension': first_dimension,
    'first_actions': first_actions,
    'first_custom_id': first_custom_id,
    'after_select_action': selected['interaction']['action'],
    'resolved': selected['interview_state']['resolved'],
    'unresolved': selected['interview_state']['unresolved'],
    'ambiguity_score': selected['interview_state']['ambiguity_score'],
    'next_dimension': next_card['card']['proposal_card']['dimension'],
    'next_actions': [component['action'] for component in next_card['card']['components']],
}, ensure_ascii=False, indent=2))
