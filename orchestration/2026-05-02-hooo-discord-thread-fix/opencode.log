import contextlib, io, json, tempfile
from pathlib import Path
from jinwang_jarvis.cli import main

with tempfile.TemporaryDirectory(prefix='hooo-smoke-') as d:
    root = Path(d)
    config = root / 'pipeline.yaml'
    config.write_text(f'''
workspace_root: {root.as_posix()}
wiki_root: /home/jinwang/wiki
accounts:
  - personal
mail:
  snapshot_dir: data/snapshots/mail
calendar:
  snapshot_dir: data/snapshots/calendar
  calendar_id: primary
state:
  database: state/personal_intel.db
  checkpoints: state/checkpoints.json
hermes:
  integration_mode: boundary-cli
  deliver_channel: discord-origin
reproducibility:
  packaging: pyproject
  config_format: yaml
  project_name: jinwang-jarvis
''', encoding='utf-8')

    def call(args):
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            code = main(args)
        payload = json.loads(buf.getvalue())
        if code != 0:
            raise SystemExit(f'command failed {args}: {payload}')
        return payload

    start = call(['hooo', 'start', '--config', str(config), '--goal', 'Manual smoke Discord thread flow', '--origin-platform', 'discord', '--origin-channel-id', 'smoke-channel', '--origin-message-id', 'smoke-message', '--auto-open-thread', '--thread-name', 'smoke thread'])
    run_id = start['run_id']
    call(['hooo', 'turn', '--config', str(config), '--run-id', run_id, '--message', 'Acceptance: smoke evidence is recorded'])
    call(['hooo', 'seed', '--config', str(config), '--run-id', run_id])
    call(['hooo', 'run', '--config', str(config), '--run-id', run_id])
    call(['hooo', 'evaluate', '--config', str(config), '--run-id', run_id])
    evolve = call(['hooo', 'evolve', '--config', str(config), '--run-id', run_id])
    status = call(['hooo', 'status', '--config', str(config), '--run-id', run_id])
    export = call(['hooo', 'export', '--config', str(config), '--run-id', run_id])
    handoff = root / 'data' / 'houroboros' / run_id / 'thread_handoff.json'
    print(json.dumps({
        'run_id': run_id,
        'final_phase': evolve['phase'],
        'status_phase': status['phase'],
        'thread_state': status['origin']['thread']['state'],
        'handoff_exists': handoff.exists(),
        'export_has_thread_metadata': export['status']['origin']['thread']['state'] == 'pending',
        'artifact_count': len(status['artifacts']),
    }, ensure_ascii=False, sort_keys=True))
