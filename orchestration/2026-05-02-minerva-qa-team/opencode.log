import json
import shutil
import subprocess
import sys
from pathlib import Path
root = Path('/tmp/opencode/minerva-qa-manual-local')
if root.exists():
    shutil.rmtree(root)
root.mkdir(parents=True)
config = root / 'pipeline.yaml'
config.write_text(f'''
workspace_root: {root.as_posix()}
wiki_root: {root.as_posix()}/wiki
accounts:
  - qa
mail:
  snapshot_dir: data/snapshots/mail
calendar:
  snapshot_dir: data/snapshots/calendar
  calendar_id: primary
state:
  database: state/personal_intel.db
  checkpoints: state/checkpoints.json
hermes:
  integration_mode: boundary-cli
  deliver_channel: discord-qa
reproducibility:
  packaging: pyproject
  config_format: yaml
  project_name: jinwang-jarvis
''', encoding='utf-8')
base = [sys.executable, '-m', 'jinwang_jarvis.cli', 'minerva']
def run(args):
    completed = subprocess.run(base + args, check=True, capture_output=True, text=True)
    payload = json.loads(completed.stdout)
    print(json.dumps({'cmd': ' '.join(args[:1]), 'phase': payload.get('phase') or payload.get('status', {}).get('phase'), 'keys': sorted(payload.keys())}, ensure_ascii=False))
    return payload
started = run(['start', '--config', str(config), '--goal', 'QA isolated workflow', '--origin-platform', 'discord', '--origin-channel-id', 'c-qa', '--origin-thread-id', 't-qa'])
run_id = started['run_id']
run(['turn', '--config', str(config), '--run-id', run_id, '--message', 'Acceptance: CLI artifacts stay under temp workspace'])
run(['seed', '--config', str(config), '--run-id', run_id])
run(['run', '--config', str(config), '--run-id', run_id])
run(['evaluate', '--config', str(config), '--run-id', run_id])
run(['evolve', '--config', str(config), '--run-id', run_id])
status = run(['status', '--config', str(config), '--run-id', run_id])
exported = run(['export', '--config', str(config), '--run-id', run_id])
print(json.dumps({
    'manual_root': str(root),
    'run_id': run_id,
    'origin': status['origin'],
    'artifact_count': len(status['artifacts']),
    'artifacts': status['artifacts'],
    'latest_drift_contains_no_acceptance_drift': 'No acceptance drift detected' in status['latest_drift'],
    'export_has_artifacts': bool(exported['artifacts']),
}, ensure_ascii=False, indent=2))
