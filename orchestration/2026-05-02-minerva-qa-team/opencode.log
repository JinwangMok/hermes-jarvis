import ast
from pathlib import Path
files = [Path('src/jinwang_jarvis/minerva.py'), Path('src/jinwang_jarvis/cli.py')]
patterns = []
for path in files:
    tree = ast.parse(path.read_text(encoding='utf-8'), filename=str(path))
    for node in ast.walk(tree):
        if isinstance(node, ast.Import):
            for alias in node.names:
                if alias.name.split('.')[0] in {'subprocess','requests','urllib','socket','os'}:
                    patterns.append((str(path), node.lineno, f'import {alias.name}'))
        if isinstance(node, ast.ImportFrom):
            mod = (node.module or '').split('.')[0]
            if mod in {'subprocess','requests','urllib','socket','os'}:
                patterns.append((str(path), node.lineno, f'from {node.module} import ...'))
        if isinstance(node, ast.Call):
            func = node.func
            name = ''
            if isinstance(func, ast.Name):
                name = func.id
            elif isinstance(func, ast.Attribute):
                parts = []
                cur = func
                while isinstance(cur, ast.Attribute):
                    parts.append(cur.attr)
                    cur = cur.value
                if isinstance(cur, ast.Name):
                    parts.append(cur.id)
                name = '.'.join(reversed(parts))
            if name in {'eval','exec','subprocess.run','os.system','requests.get','requests.post','urllib.request.urlopen'}:
                patterns.append((str(path), node.lineno, name))
print({'dangerous_patterns': patterns, 'ok': not patterns})
