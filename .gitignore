__pycache__/
.pytest_cache/
*.pyc

# Runtime/generated local artifacts. These may contain private mail/calendar/watch data.
/data/
/state/
/.hermes/
/orchestration/**/opencode*.log
/orchestration/**/prompt*.txt

# ZeusOS rearchitecture local/private roots.
/credentials/**
!/credentials/
!/credentials/**/
!/credentials/**/README.md
/vmem/**
!/vmem/
!/vmem/README.md
/assets/tmp/**
!/assets/tmp/
!/assets/tmp/README.md
/workspace/**
!/workspace/
!/workspace/README.md

# In-repo wiki placeholder is trackable, but future generated/private wiki payloads need explicit policy before commit.
/wiki/**
!/wiki/
!/wiki/README.md

config/pipeline.local.yaml
config/sender-map.md

# Vendored Hermes skills should not carry generated/runtime payloads.
/skills/**/.cache/
/skills/**/.venv/
/skills/**/venv/
/skills/**/tmp/
/skills/**/reports/*.log

# Local work backups / private audio samples.
/.work-backups/
/data/styled-voice-samples/

# Local compressed historical archives.
/.local-archive/
